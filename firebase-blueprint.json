{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Startup": {
      "title": "Startup",
      "description": "Startup project details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "idea": { "type": "string" },
        "problem": { "type": "string" },
        "targetUsers": { "type": "string" },
        "market": { "type": "string" },
        "competitors": { "type": "string" },
        "status": { "type": "string", "enum": ["idea", "validation", "market", "mvp", "launch"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "idea"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "AI generated startup analysis",
      "type": "object",
      "properties": {
        "startupId": { "type": "string" },
        "userId": { "type": "string" },
        "report": { "type": "object" },
        "validation": { "type": "object" },
        "competitors": { "type": "array" },
        "mvp": { "type": "object" },
        "roadmap": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["startupId", "userId"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Message in the AI mentor chat",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "startupId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content"]
    },
    "AgentAction": {
      "title": "AgentAction",
      "description": "Action requested by the AI agent",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "startupId": { "type": "string" },
        "type": { "type": "string", "enum": ["send_email", "create_task", "market_research", "draft_content"] },
        "status": { "type": "string", "enum": ["pending", "approved", "denied", "completed", "failed"] },
        "details": { "type": "object" },
        "result": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "startupId", "type", "status"]
    },
    "DailyBriefing": {
      "title": "DailyBriefing",
      "description": "Daily AI generated briefing",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "startupId": { "type": "string" },
        "date": { "type": "string" },
        "marketUpdates": { "type": "array" },
        "competitorActivity": { "type": "array" },
        "opportunities": { "type": "array" },
        "risks": { "type": "array" },
        "recommendedActions": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "startupId", "date"]
    },
    "MarketIntelligence": {
      "title": "MarketIntelligence",
      "description": "Continuous market signals",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "startupId": { "type": "string" },
        "signals": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "startupId"]
    },
    "WeeklyReport": {
      "title": "WeeklyReport",
      "description": "Weekly progress summary",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "startupId": { "type": "string" },
        "weekRange": { "type": "string" },
        "progress": { "type": "string" },
        "keyInsights": { "type": "array" },
        "risks": { "type": "array" },
        "strategyAdjustments": { "type": "array" },
        "nextWeekPriorities": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "startupId", "weekRange"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/startups/{startupId}": {
      "schema": "Startup",
      "description": "Startup projects"
    },
    "/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "AI analyses"
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Chat messages"
    },
    "/agent_actions/{actionId}": {
      "schema": "AgentAction",
      "description": "Agent actions"
    },
    "/briefings/{briefingId}": {
      "schema": "DailyBriefing",
      "description": "Daily briefings"
    },
    "/intelligence/{intelligenceId}": {
      "schema": "MarketIntelligence",
      "description": "Market intelligence"
    },
    "/weekly_reports/{reportId}": {
      "schema": "WeeklyReport",
      "description": "Weekly reports"
    }
  }
}
